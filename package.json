{
  "name": "rich-markdown-diff",
  "packageManager": "pnpm@10.33.0",
  "publisher": "phine-apps",
  "displayName": "Rich Markdown Diff",
  "description": "Professional visual Markdown diff with Math, Mermaid, and Git integration for better document reviews.",
  "version": "1.4.0",
  "icon": "images/icon.png",
  "author": "phine-apps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/phine-apps/rich-markdown-diff"
  },
  "bugs": {
    "url": "https://github.com/phine-apps/rich-markdown-diff/issues"
  },
  "homepage": "https://github.com/phine-apps/rich-markdown-diff#readme",
  "keywords": [
    "markdown",
    "diff",
    "compare",
    "git",
    "scm",
    "visualization",
    "preview",
    "rendered"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Visualization",
    "SCM Providers"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onView:scm"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rich-markdown-diff.selectForCompare",
        "title": "%rich-markdown-diff.selectForCompare.title%",
        "category": "%rich-markdown-diff.category%",
        "enablement": "editorLangId == 'markdown' || resourceLangId == 'markdown'"
      },
      {
        "command": "rich-markdown-diff.compareWithSelected",
        "title": "%rich-markdown-diff.compareWithSelected.title%",
        "category": "%rich-markdown-diff.category%",
        "enablement": "(editorLangId == 'markdown' || resourceLangId == 'markdown') && rich-markdown-diff.hasSelectedForCompare"
      },
      {
        "command": "rich-markdown-diff.showRenderedDiff",
        "title": "%rich-markdown-diff.showRenderedDiff.title%",
        "category": "%rich-markdown-diff.category%",
        "icon": "$(diff)"
      },
      {
        "command": "rich-markdown-diff.diffClipboard",
        "title": "%rich-markdown-diff.diffClipboard.title%",
        "category": "%rich-markdown-diff.category%",
        "enablement": "editorLangId == 'markdown' || resourceLangId == 'markdown' || activeCustomEditorId == 'vscode.markdown.preview.editor'"
      },
      {
        "command": "rich-markdown-diff.toggleInlineView",
        "title": "%rich-markdown-diff.toggleInlineView.title%",
        "category": "%rich-markdown-diff.category%",
        "icon": "$(split-horizontal)",
        "enablement": "rich-markdown-diff.isDiffActive"
      },
      {
        "command": "rich-markdown-diff.toggleFoldUnchanged",
        "title": "%rich-markdown-diff.toggleFoldUnchanged.title%",
        "category": "%rich-markdown-diff.category%",
        "icon": "$(fold)",
        "enablement": "rich-markdown-diff.isDiffActive"
      },
      {
        "command": "rich-markdown-diff.nextChange",
        "title": "%rich-markdown-diff.nextChange.title%",
        "category": "%rich-markdown-diff.category%",
        "icon": "$(arrow-down)",
        "enablement": "rich-markdown-diff.isDiffActive"
      },
      {
        "command": "rich-markdown-diff.prevChange",
        "title": "%rich-markdown-diff.prevChange.title%",
        "category": "%rich-markdown-diff.category%",
        "icon": "$(arrow-up)",
        "enablement": "rich-markdown-diff.isDiffActive"
      }
    ],
    "keybindings": [
      {
        "command": "rich-markdown-diff.nextChange",
        "key": "f7",
        "mac": "f7",
        "when": "rich-markdown-diff.isDiffActive"
      },
      {
        "command": "rich-markdown-diff.prevChange",
        "key": "shift+f7",
        "mac": "shift+f7",
        "when": "rich-markdown-diff.isDiffActive"
      },
      {
        "command": "rich-markdown-diff.nextChange",
        "key": "alt+f5",
        "when": "rich-markdown-diff.isDiffActive"
      },
      {
        "command": "rich-markdown-diff.prevChange",
        "key": "shift+alt+f5",
        "when": "rich-markdown-diff.isDiffActive"
      },
      {
        "command": "rich-markdown-diff.diffClipboard",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus && editorLangId == markdown"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "rich-markdown-diff.toggleInlineView",
          "when": "rich-markdown-diff.isDiffActive"
        },
        {
          "command": "rich-markdown-diff.toggleFoldUnchanged",
          "when": "rich-markdown-diff.isDiffActive"
        },
        {
          "command": "rich-markdown-diff.nextChange",
          "when": "rich-markdown-diff.isDiffActive"
        },
        {
          "command": "rich-markdown-diff.prevChange",
          "when": "rich-markdown-diff.isDiffActive"
        },
        {
          "command": "rich-markdown-diff.compareWithSelected",
          "when": "rich-markdown-diff.hasSelectedForCompare"
        },
        {
          "command": "rich-markdown-diff.showRenderedDiff",
          "when": "(editorLangId == markdown || resourceLangId == markdown) && rich-markdown-diff.canShowRenderedDiff"
        },
        {
          "command": "rich-markdown-diff.showRenderedDiff",
          "when": "activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'"
        }
      ],
      "editor/title": [
        {
          "command": "rich-markdown-diff.showRenderedDiff",
          "group": "navigation",
          "when": "(resourceLangId == markdown && (rich-markdown-diff.canShowRenderedDiff || isInDiffEditor)) || (editorLangId == markdown && rich-markdown-diff.canShowRenderedDiff) || activeWebviewPanelId == 'markdown.preview' || activeCustomEditorId == 'vscode.markdown.preview.editor'"
        },
        {
          "command": "rich-markdown-diff.prevChange",
          "group": "navigation@1",
          "when": "rich-markdown-diff.isDiffActive"
        },
        {
          "command": "rich-markdown-diff.nextChange",
          "group": "navigation@2",
          "when": "rich-markdown-diff.isDiffActive"
        },
        {
          "command": "rich-markdown-diff.toggleInlineView",
          "group": "navigation@3",
          "when": "rich-markdown-diff.isDiffActive"
        },
        {
          "command": "rich-markdown-diff.toggleFoldUnchanged",
          "group": "navigation@4",
          "when": "rich-markdown-diff.isDiffActive"
        }
      ],
      "explorer/context": [
        {
          "command": "rich-markdown-diff.selectForCompare",
          "group": "modification",
          "when": "resourceLangId == markdown && !rich-markdown-diff.hasSelectedForCompare && !listMultiSelection"
        },
        {
          "command": "rich-markdown-diff.compareWithSelected",
          "group": "modification",
          "when": "resourceLangId == markdown && rich-markdown-diff.hasSelectedForCompare && !listMultiSelection"
        },
        {
          "command": "rich-markdown-diff.showRenderedDiff",
          "title": "%rich-markdown-diff.showRenderedDiff.title%",
          "group": "modification",
          "when": "resourceLangId == markdown && listMultiSelection"
        }
      ],
      "editor/context": [
        {
          "command": "rich-markdown-diff.selectForCompare",
          "group": "modification",
          "when": "(editorLangId == markdown || resourceLangId == markdown) && !rich-markdown-diff.hasSelectedForCompare"
        },
        {
          "command": "rich-markdown-diff.diffClipboard",
          "group": "modification@1",
          "when": "editorLangId == markdown || resourceLangId == markdown"
        },
        {
          "command": "rich-markdown-diff.compareWithSelected",
          "group": "modification",
          "when": "(editorLangId == markdown || resourceLangId == markdown) && rich-markdown-diff.hasSelectedForCompare"
        },
        {
          "command": "rich-markdown-diff.showRenderedDiff",
          "group": "modification",
          "when": "(editorLangId == markdown || resourceLangId == markdown) && rich-markdown-diff.canShowRenderedDiff"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "rich-markdown-diff.showRenderedDiff",
          "group": "inline@1",
          "icon": "$(diff)",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "title": "Rich Markdown Diff",
      "properties": {
        "rich-markdown-diff.showGutterMarkers": {
          "type": "boolean",
          "default": true,
          "description": "%rich-markdown-diff.showGutterMarkers.description%"
        },
        "rich-markdown-diff.showGitBlame": {
          "type": "boolean",
          "default": true,
          "description": "%rich-markdown-diff.showGitBlame.description%"
        },
        "rich-markdown-diff.lineHoverDelay": {
          "type": "number",
          "default": 500,
          "description": "%rich-markdown-diff.lineHoverDelay.description%"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "rich-markdown-diff.diffPreview",
        "displayName": "%rich-markdown-diff.customEditor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run esbuild-base -- --production",
    "esbuild-base": "node esbuild.js",
    "esbuild": "pnpm run esbuild-base -- --sourcemap",
    "esbuild-watch": "pnpm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./ && pnpm run esbuild",
    "watch": "pnpm run esbuild-watch",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js",
    "test:unit": "pnpm run compile && mocha ./out/test/unit/**/*.test.js",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "pnpm exec ovsx publish",
    "test:visual": "pnpm exec playwright test",
    "test:visual:docker": "docker compose run --rm --service-ports playwright sh -c \"pnpm install --store-dir /pnpm-store && pnpm exec playwright test\"",
    "test:visual:update": "docker compose run --rm --service-ports playwright sh -c \"pnpm install --store-dir /pnpm-store && pnpm exec playwright test --update-snapshots\""
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/vscode": "1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-jsdoc": "^63.0.13",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "mocha": "^11.7.6",
    "ovsx": "^1.0.2",
    "playwright": "1.60.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "@iktakahiro/markdown-it-katex": "^4.0.1",
    "@marp-team/marp-core": "^4.3.1",
    "@vscode/l10n": "^0.0.18",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "htmldiff-js": "^1.0.5",
    "markdown-it": "^14.3.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-github-alerts": "^1.0.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "sanitize-html": "^2.17.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "esbuild",
      "keytar"
    ]
  }
}
